# Anypress Configuration
# Copy this file to .env and fill in your values

# Anytype Local API
ANYTYPE_API_URL=http://127.0.0.1:31009
ANYTYPE_API_KEY=your_anytype_api_key_here
# Optional: limit sync to a single space. Leave empty to sync from ALL spaces.
ANYTYPE_SPACE_ID=

# GitHub
GITHUB_REPO=AnhMinh245/anypress
GITHUB_TOKEN=your_github_personal_access_token_here

# Dashboard
DASHBOARD_PORT=3000
